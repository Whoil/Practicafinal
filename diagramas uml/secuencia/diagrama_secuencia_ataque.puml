@startuml
title Secuencia - Ataque a enemigo
skinparam shadowing false

actor Jugador
participant "Controlador" as Ctrl
participant "Partida" as P
participant "Enemigo" as E

Jugador -> Ctrl : SPACE
Ctrl -> P : atacar(fila, col)
P -> E : recibirDaño(daño)
note right : calcularDano() interno
P --> Ctrl : true / false
Ctrl -> Jugador : feedback visual
@enduml
