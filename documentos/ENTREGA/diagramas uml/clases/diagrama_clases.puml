@startuml
title Diagrama de Paquetes - Escape de la Mazmorra

skinparam packageStyle rectangle
skinparam defaultFontSize 12
skinparam shadowing false

rectangle "modelo.juego" as juego #FFE0E0
rectangle "modelo.mapa" as mapa #E0FFE0
rectangle "modelo.personajes" as personajes #E0E0FF
rectangle "modelo.objetos" as objetos #FFFFE0
rectangle "Estructuras" as estructuras #FFE0FF
rectangle "json" as json #E0FFFF
rectangle "vista" as vista #FFE8D0
rectangle "control" as control #D0FFE8

juego --> mapa
juego --> personajes
juego --> objetos
juego --> estructuras
juego --> json
juego --> vista
control --> juego
control --> vista
vista --> juego
vista --> json

note right of juego
  Contiene: Partida, Mazmorra, Puerta,
  Estados y DTOs de capa de juego
end note

note right of estructuras
  Contiene: ListaSE, ListaDE, Cola,
  Grafo e iteradores (Parte A)
end note

@enduml
